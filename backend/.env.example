DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naukograd?schema=public"
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Create strong random values before production
JWT_ACCESS_SECRET="change-me-to-a-long-random-secret"
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=15
CONSENT_DOCUMENT_VERSION="v1.0"
PAYMENT_WEBHOOK_SECRET="change-me-webhook-secret"

# 32-byte key in base64. Example generation:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="change-me-base64-32-bytes"
